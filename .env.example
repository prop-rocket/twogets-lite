# Supabase — find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose this to the browser. Used for admin operations
# (signed URLs for verification documents, admin moderation).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Absolute URL of the deployed app (used for OAuth redirects & SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
